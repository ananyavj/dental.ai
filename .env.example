# Copy this file to .env and fill in your keys
# All services have free tiers sufficient for demo/development

# Google Gemini API — REQUIRED for all AI features
# Get free key at: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — NOT YET WIRED (installed for Phase 2)
# Get free project at: https://supabase.com/
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudinary — NOT YET USED (installed for Phase 3)
# Get free account at: https://cloudinary.com/
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=dental_ai_uploads

# YouTube Data API v3 — OPTIONAL (mock data used if absent)
# Enable at: https://console.cloud.google.com/ → YouTube Data API v3
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
